# Dependencies (reinstalled in container)
node_modules
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (rebuilt in container)
dist
*.tsbuildinfo

# Environment and secrets (never copy into image)
.env
.env.*
!.env.example

# Version control
.git
.gitignore

# IDE and OS
.idea
.vscode
.DS_Store
Thumbs.db

# Docs and misc (optional: remove if you want them in image)
*.md
!README.md

# Tests (optional: remove if you need tests in image)
coverage
.nyc_output
*.test.ts
*.spec.ts
__tests__
e2e

# Docker
Dockerfile
docker-compose*.yml
.dockerignore
